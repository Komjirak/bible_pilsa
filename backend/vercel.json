{
  "version": 2,
  "buildCommand": "npx prisma generate && npm run build && npx prisma db push --accept-data-loss",
  "outputDirectory": ".",
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "includeFiles": "dist/**"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
