# 서버 설정
PORT=3001
NODE_ENV=development

# 데이터베이스 (PostgreSQL)
DATABASE_URL=postgresql://bible_user:password@localhost:5432/bible_pilsa?schema=public

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# 토스 OAuth2 (앱인토스 발급)
TOSS_CLIENT_ID=your-toss-client-id
TOSS_CLIENT_SECRET=your-toss-client-secret
TOSS_TOKEN_ENDPOINT=https://oauth.toss.im/oauth2/token

# 토스 로그인 개인정보 복호화
TOSS_DECRYPT_KEY=your-base64-decrypt-key
TOSS_DECRYPT_AAD=TOSS

# 토스 리워드 프로모션 API (executePromotion)
TOSS_PROMOTION_CODE=your-promotion-code
TOSS_PROMOTION_API_KEY=your-promotion-api-key

# 7일 완주 포인트 지급액 (단위: 원)
WEEKLY_COMPLETE_POINT_AMOUNT=10

# Redis (BullMQ - 포인트 지급 큐)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# CORS
ALLOWED_ORIGIN=https://komjirak-bible.apps.tossmini.com

# Rate Limit
THROTTLE_TTL=60
THROTTLE_LIMIT=30
